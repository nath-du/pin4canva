{
  "manifest_version": 3,
  "name": "Pin4Canva",
  "version": "1.1.0",
  "description": "ELementi gratuiti per Canva: Cerca da Pinterest, rimuovi sfondo, trascina su Canva.",
  "permissions": ["storage", "tabs", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://*.pinterest.com/*",
    "https://*.pinimg.com/*",
    "https://*.canva.com/*",
    "https://api.remove.bg/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.pinterest.com/*"],
      "js": ["content-pinterest-patch.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://*.canva.com/*"],
      "js": ["content-canva.js"],
      "css": ["content-canva.css"],
      "run_at": "document_idle"
    }
  ]
}
